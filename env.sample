# =============================================================================
# User Behavior Analytics - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Docker Compose services set their own env vars directly in docker-compose.yml,
# so .env is only needed for local (non-Docker) development.

# --- Kafka ---
# Inside Docker: kafka:29092 (internal listener)
# From host:     localhost:9092 (external listener)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Producer ---
# Interval between events in seconds (lower = more events)
EVENT_INTERVAL=1.0

# --- AWS / LocalStack (S3 Data Lake) ---
# Inside Docker: http://localstack:4566
# From host:     http://localhost:4566
S3_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Redshift (Data Warehouse) ---
# Optional: only needed if running sync_to_redshift()
# REDSHIFT_URL=jdbc:postgresql://localhost:4566/analytics
# REDSHIFT_USER=test
# REDSHIFT_PASS=test1234
# REDSHIFT_DRIVER=org.postgresql.Driver

# --- Trino (SQL Query Engine) ---
# TRINO_HOST=localhost
# TRINO_PORT=8082
# TRINO_USER=test
# TRINO_PASSWORD=test1234

# --- Spark ---
# Only needed for local development outside Docker
# SPARK_MASTER=local[*]
